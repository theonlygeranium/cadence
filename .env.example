# Cadence — Environment Variables Template
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cadence.jgeronimo.com
NODE_ENV=development

# ─────────────────────────────────────────────
# Database (PostgreSQL via Drizzle ORM)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://cadence:your_password@localhost:5432/cadence
POSTGRES_PASSWORD=your_postgres_password
ENCRYPTION_KEY=your_32_byte_hex_key_for_aes_256_gcm

# ─────────────────────────────────────────────
# Authentication (NextAuth.js v5)
# ─────────────────────────────────────────────
NEXTAUTH_URL=https://cadence.jgeronimo.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars

# ─────────────────────────────────────────────
# Plaid API
# ─────────────────────────────────────────────
# PLAID_ENV: sandbox | development | production
PLAID_CLIENT_ID=6a28c468cd6f99000ddddc6a
PLAID_ENV=sandbox
# Use the secret matching PLAID_ENV:
PLAID_SECRET=f6ee0e03b617b26f6c50b03eda776d
# When upgrading to production, swap to:
# PLAID_SECRET=d6b3cd89bdabb9a65cc44e67fb4643

# ─────────────────────────────────────────────
# Ollama (Self-hosted LLM on Schubert)
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.6:latest
# Set to true ONLY if Ollama is on a remote host (non-localhost):
# OLLAMA_ALLOW_REMOTE=false

# ─────────────────────────────────────────────
# SMTP (Transactional Email — billing alerts, weekly digest)
# Credentials to be provided by Jeffrey.
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cadence.jgeronimo.com

# ─────────────────────────────────────────────
# Schubert Infrastructure (Reference — do not change)
# ─────────────────────────────────────────────
# Production server: Ubuntu 26.04 LTS, NVIDIA RTX PRO 4500 (32 GB VRAM)
# Internal IP (Tailscale): 100.86.47.6
# Caddy reverse proxy handles TLS termination.
# Deployment requires explicit approval from Jeffrey.
# SCHUBERT_HOST=100.86.47.6